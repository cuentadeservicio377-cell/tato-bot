# Copia este archivo como .env y llena los valores
# NUNCA subas el .env a GitHub

# Telegram
TELEGRAM_TOKEN=aqui_va_tu_token_de_botfather

# Groq
GROQ_API_KEY=aqui_va_tu_api_key_de_groq

# PostgreSQL (Railway)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Google OAuth
GOOGLE_CLIENT_ID=aqui_va_tu_google_client_id
GOOGLE_CLIENT_SECRET=aqui_va_tu_google_client_secret
CALLBACK_URL=https://tu-dominio.railway.app/oauth/callback

# Railway
RAILWAY_PUBLIC_URL=https://tu-dominio.railway.app
PORT=8080

# ============================================================
# Configuración específica Tato Bot
# ============================================================
TATO_USER_ID=aqui_va_el_telegram_user_id_de_tato
GACETA_EMAIL_SENDER=aqui_va_el_email_desde_el_que_llega_gaceta
SHEETS_EXPEDIENTES_ID=aqui_va_el_id_de_la_hoja_google_sheets
SHEETS_EXPEDIENTES_RANGE=Expedientes!A:N
